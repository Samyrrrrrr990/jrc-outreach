# =============================================================================
# JRC Outreach — environment configuration
# Copy to `.env` for local runs. In CI, set each of these as a GitHub Actions
# repository secret. NEVER commit a filled-in .env.
# =============================================================================

# --- Google Sheets (service account) ----------------------------------------
# The whole service-account JSON key, as a single-line string. In GitHub
# Actions, paste the raw JSON into a secret named GOOGLE_SERVICE_ACCOUNT_JSON.
# Locally you may instead point GOOGLE_SERVICE_ACCOUNT_FILE at a file path.
GOOGLE_SERVICE_ACCOUNT_JSON=
# GOOGLE_SERVICE_ACCOUNT_FILE=./service-account.json

# The spreadsheet ID (the long token in the Sheet URL between /d/ and /edit).
# Share the Sheet with the service account's client_email (Editor access).
SHEET_ID=

# --- Privatemail SMTP (sending) ----------------------------------------------
SMTP_HOST=mail.privateemail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=

# --- Privatemail IMAP (Sent append + reply detection) ------------------------
IMAP_HOST=mail.privateemail.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=
IMAP_PASS=
# Mailbox names as they appear on the server. Defaults suit most providers.
IMAP_SENT_MAILBOX=Sent
IMAP_INBOX_MAILBOX=INBOX

# --- Sender identity (appears in the emails) ---------------------------------
SENDER_NAME=
SENDER_EMAIL=
# Optional; defaults to SENDER_EMAIL if unset.
REPLY_TO_EMAIL=
# Optional HTTPS one-click unsubscribe endpoint. If omitted, only the
# mailto: unsubscribe (to SENDER_EMAIL) is advertised.
UNSUBSCRIBE_URL=

# --- Behaviour ---------------------------------------------------------------
# Safety switch. When true, nothing is sent and no Sheet writes happen.
DRY_RUN=false
LOG_LEVEL=info
# Append a daily run summary to a "Log" tab in the Sheet as well as stdout.
LOG_TO_SHEET=true
