{
  "name": "jrc-outreach",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Automated, compliant academic/sponsor outreach CRM driven by Google Sheets, run on GitHub Actions.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "cli": "tsx src/cli.ts",
    "scrape": "tsx src/cli.ts scrape",
    "send": "tsx src/cli.ts send",
    "daily": "tsx src/cli.ts run-daily",
    "replies": "tsx src/cli.ts run-replies",
    "doctor": "tsx src/cli.ts doctor"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "googleapis": "^144.0.0",
    "imapflow": "^1.0.171",
    "nodemailer": "^6.9.16",
    "robots-parser": "^3.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
